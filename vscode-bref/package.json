{
  "name": "vscode-bref",
  "displayName": "Bref",
  "description": "Token cost reduction for LLM API calls",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alivcor/bref"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bref.compressSelection",
        "title": "Bref: Compress Selection"
      },
      {
        "command": "bref.showStats",
        "title": "Bref: Show Stats"
      },
      {
        "command": "bref.recordPrompt",
        "title": "Bref: Record Prompt Compression"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bref",
          "title": "Bref",
          "icon": "$(dashboard)"
        }
      ]
    },
    "views": {
      "bref": [
        {
          "id": "bref.statsView",
          "name": "Stats",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Bref",
      "properties": {
        "bref.compressionRatio": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Target compression ratio (0.1 = aggressive, 1.0 = no compression)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node esbuild.js",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "esbuild": "node esbuild.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  }
}
