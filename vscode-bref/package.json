{
  "name": "vscode-bref",
  "displayName": "Bref - AI Prompt Compression & Token Cost Optimizer",
  "description": "Reduce LLM API costs by 40-60%. Compress prompts with TF-IDF entropy scoring, cache responses, route to cheaper models. Works with GPT, Claude, Copilot, Kiro, and any LLM agent. Save tokens, cut your AI bill.",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alivcor/bref"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bref.compressSelection",
        "title": "Bref: Compress Selection"
      },
      {
        "command": "bref.showStats",
        "title": "Bref: Show Stats"
      },
      {
        "command": "bref.recordPrompt",
        "title": "Bref: Record Prompt Compression"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bref",
          "title": "Bref",
          "icon": "$(dashboard)"
        }
      ]
    },
    "views": {
      "bref": [
        {
          "id": "bref.statsView",
          "name": "Stats",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Bref",
      "properties": {
        "bref.compressionRatio": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Target compression ratio (0.1 = aggressive, 1.0 = no compression)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node esbuild.js",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "esbuild": "node esbuild.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  },
  "publisher": "abhinandandubey",
  "author": {
    "name": "Abhinandan Dubey",
    "url": "https://alivcor.github.io"
  },
  "keywords": [
    "ai",
    "llm",
    "token",
    "compression",
    "prompt",
    "cost",
    "gpt",
    "claude",
    "copilot",
    "kiro",
    "api",
    "optimize",
    "cache",
    "tiktoken",
    "openai"
  ],
  "homepage": "https://github.com/alivcor/bref",
  "bugs": {
    "url": "https://github.com/alivcor/bref/issues"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  }
}
